# ShellCheck configuration for han-solo

# Enable all optional checks
enable=all

# Set minimum severity level (error, warning, info, style)
severity=warning

# Specify shell dialect
shell=bash

# Disable specific checks that don't apply to our use case
# SC2034: Variable appears unused (we use exported vars)
# SC2155: Declare and assign separately to avoid masking return values
disable=SC2034,SC2155

# External sources we can't analyze
# Scripts sourced from other locations
external-sources=true